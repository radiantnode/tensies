# Copy to .env.prod and fill in real secrets. EVERY secret is delivered to its
# container as a MOUNTED FILE (not an env var, so nothing shows up in
# `docker inspect` / /proc/<pid>/environ). The values below seed those files.
# Materialise them all from .env.prod, then bring the stack up:
#
#   set -a; . ./.env.prod; set +a
#   mkdir -p ops/secrets
#   printf %s  "$JWT_SECRET"             > ops/secrets/jwt_secret
#   printf %s  "$STATS_TOKEN"            > ops/secrets/stats_token
#   printf %s  "$METRICS_TOKEN"          > ops/secrets/metrics_token
#   printf %s  "$POSTGRES_PASSWORD"      > ops/secrets/pg_password
#   printf %s  "$REDIS_PASSWORD"         > ops/secrets/redis_password
#   printf %s  "$GRAFANA_ADMIN_PASSWORD" > ops/secrets/grafana_admin_password
#   printf 'redis://:%s@redis:6379/0'              "$REDIS_PASSWORD"    > ops/secrets/redis_url
#   printf 'postgresql://tensies:%s@postgres:5432/tensies' "$POSTGRES_PASSWORD" > ops/secrets/pg_dsn
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
#
# .env.prod and ops/secrets/ are gitignored — never commit real secrets.

# Strong, unique values (e.g. `openssl rand -hex 32`):
REDIS_PASSWORD=change-me
POSTGRES_PASSWORD=change-me
GRAFANA_ADMIN_PASSWORD=change-me
METRICS_TOKEN=change-me
STATS_TOKEN=change-me
JWT_SECRET=change-me

# WebAuthn relying party — must match the domain users register passkeys on.
# RP_ID is the domain (no scheme/port); ORIGIN defaults to ALLOWED_ORIGINS.
WEBAUTHN_RP_ID=tensies.example.com

# Public origin of the app, used for the WS Origin allowlist (audit M3) and as
# Grafana's root URL / Live allowed origin. Comma-separate multiple origins.
ALLOWED_ORIGINS=https://tensies.example.com
GRAFANA_ROOT_URL=https://grafana.example.com

# Public URL the app is served from. Makes the served index.html emit an ABSOLUTE
# og:image/twitter:image so the iOS share sheet (and social crawlers) can fetch the
# Tensies icon for the invite-link preview. Leave unset in dev to keep it relative.
APP_URL=https://tensies.app

# Host bind for direct Grafana access (container listens on 3000). Loopback by
# default — reach it over an SSH tunnel. Set to 0.0.0.0:8889 to expose on the
# host's network, but don't put Grafana's admin UI on the public internet.
GRAFANA_PUBLISH=127.0.0.1:8889

# Where to publish the ingress on the host. This now binds the nginx service
# (which load-balances across the scaled `web` replicas), so point your TLS
# proxy / cloudflared at this address. Loopback by default.
WEB_PUBLISH=127.0.0.1:8000

# Number of trusted proxies that append to X-Forwarded-For (TRUST_PROXY_HEADERS
# is forced on in prod). 1 = a single LB you control. Increase if a CDN +
# your LB both append (e.g. 2). Set too high and the real client IP is wrong;
# too low and a client could spoof its IP past the per-IP limits.
TRUSTED_PROXY_HOPS=1

# Allowlist extra hosts on individual CSP directives without rewriting the whole
# policy. Space- or comma-separated. Leave blank to keep the strict same-origin
# default. Example: let Cloudflare Web Analytics run (its beacon loads a script
# and posts results to a collector):
#   CSP_EXTRA_SCRIPT_SRC=https://static.cloudflareinsights.com
#   CSP_EXTRA_CONNECT_SRC=https://cloudflareinsights.com
CSP_EXTRA_SCRIPT_SRC=
CSP_EXTRA_CONNECT_SRC=

# Derive dice from drand League of Entropy beacons instead of local RNG.
# Enables post-game Roll Trust verification. On by default in prod.
ENABLE_DRAND_ROLLING=1

# Discord game-status notifier (optional, off by default). Posts one live-
# updating card per game to an #operations-style channel. The bot token is a
# secret — keep it out of git. See docs/DISCORD.md for bot setup.
# DISCORD_ENABLED=1
# DISCORD_BOT_TOKEN=change-me
# DISCORD_CHANNEL_ID=123456789012345678
# Slash commands (/verify). Set the interactions endpoint URL in the Developer
# Portal to https://<your-host>/discord/interactions.
# DISCORD_PUBLIC_KEY=change-me
# DISCORD_APPLICATION_ID=123456789012345678
# DISCORD_GUILD_ID=123456789012345678
