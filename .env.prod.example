# Copy to .env.prod and fill in real secrets, then:
#   echo -n "$METRICS_TOKEN" > ops/secrets/metrics_token
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
# .env.prod and ops/secrets/ are gitignored — never commit real secrets.

# Strong, unique values (e.g. `openssl rand -hex 32`):
REDIS_PASSWORD=change-me
POSTGRES_PASSWORD=change-me
GRAFANA_ADMIN_PASSWORD=change-me
METRICS_TOKEN=change-me
STATS_TOKEN=change-me

# Public origin of the app, used for the WS Origin allowlist (audit M3) and as
# Grafana's root URL / Live allowed origin. Comma-separate multiple origins.
ALLOWED_ORIGINS=https://tensies.example.com
GRAFANA_ROOT_URL=https://grafana.example.com

# Where to publish the app port on the host (front it with a TLS proxy).
WEB_PUBLISH=127.0.0.1:8000
