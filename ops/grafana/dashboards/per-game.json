{
  "uid": "tensies-game",
  "title": "Tensies — Per-Game Drilldown",
  "tags": ["tensies", "game"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "2s",
  "timepicker": { "refresh_intervals": ["1s", "2s", "5s", "10s"] },
  "templating": {
    "list": [
      {
        "name": "game_code",
        "label": "Game",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "postgres" },
        "refresh": 2,
        "query": "SELECT game_code AS __text, game_code AS __value FROM games ORDER BY started_ts DESC LIMIT 200",
        "sort": 0,
        "current": { "selected": false, "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Status",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT status FROM games WHERE game_code = '$game_code'"
      }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "mappings": [
        { "type": "value", "options": { "lobby": { "color": "blue", "text": "lobby" }, "playing": { "color": "green", "text": "playing" }, "ended": { "color": "purple", "text": "ended" } } }
      ]}}
    },
    {
      "id": 2, "type": "stat", "title": "Round / Target",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT (round_num || ' / target ' || target) AS rnd FROM live_games WHERE game_code = '$game_code'"
      }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3, "type": "stat", "title": "Players",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT player_count FROM games WHERE game_code = '$game_code'"
      }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4, "type": "stat", "title": "Total rolls",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT total_rolls FROM games WHERE game_code = '$game_code'"
      }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5, "type": "stat", "title": "Rounds completed",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT count(*) FROM rounds WHERE game_code = '$game_code' AND winner_user_id IS NOT NULL"
      }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6, "type": "stat", "title": "Game age",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT extract(epoch from (coalesce(ended_ts, now()) - started_ts))::int AS age FROM games WHERE game_code = '$game_code'"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },

    {
      "id": 10, "type": "bargauge", "title": "Current round progress",
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT coalesce(name, user_id) AS metric, matched AS value FROM live_players WHERE game_code = '$game_code' ORDER BY matched DESC"
      }],
      "fieldConfig": { "defaults": { "max": 10, "min": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue" }, { "color": "green", "value": 5 }, { "color": "yellow", "value": 8 }, { "color": "red", "value": 10 }] } } },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true, "valueMode": "color" }
    },

    {
      "id": 11, "type": "timeseries", "title": "Match progression (current round)",
      "gridPos": { "h": 8, "w": 14, "x": 10, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "time_series", "rawQuery": true,
        "rawSql": "SELECT ts AS time, coalesce(e.user_id, 'unknown') AS metric, (payload->>'matched')::int AS value FROM events e WHERE e.game_code = '$game_code' AND e.type = 'roll' AND e.round_num = (SELECT round_num FROM live_games WHERE game_code = '$game_code') ORDER BY ts"
      }],
      "fieldConfig": { "defaults": { "min": 0, "max": 10, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "spanNulls": true, "showPoints": "always", "pointSize": 6, "lineWidth": 2 } } }
    },

    {
      "id": 20, "type": "logs", "title": "Live roll stream",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "grafana", "uid": "-- Grafana --" },
      "targets": [{ "refId": "A", "queryType": "measurements",
        "channel": "stream/tensies/rolls",
        "filter": { "fields": ["matched", "target", "dt_ms"] }
      }],
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending" }
    },

    {
      "id": 21, "type": "table", "title": "Rounds in this game",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT round_num AS \"#\", target AS \"Target\", winner_user_id AS \"Winner\", duration_ms AS \"Duration (ms)\", total_rolls AS \"Rolls\", started_ts AS \"Started\" FROM rounds WHERE game_code = '$game_code' ORDER BY round_num DESC"
      }],
      "fieldConfig": { "defaults": { "custom": { "align": "left" } }, "overrides": [
        { "matcher": { "id": "byName", "options": "Duration (ms)" }, "properties": [{ "id": "unit", "value": "ms" }] }
      ]}
    },

    {
      "id": 30, "type": "table", "title": "Per-player round breakdown",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT rp.round_num AS \"Round\", coalesce(ps.name_last, rp.user_id) AS \"Player\", rp.rolls AS \"Rolls\", rp.matched_at_end AS \"Final matched\", rp.time_to_first_match_ms AS \"First match (ms)\", rp.avg_dt_between_rolls_ms AS \"Avg dt (ms)\", rp.fastest_dt_ms AS \"Fastest dt\", rp.slowest_dt_ms AS \"Slowest dt\" FROM round_player rp LEFT JOIN player_stats ps ON ps.user_id = rp.user_id WHERE rp.game_code = '$game_code' ORDER BY rp.round_num DESC, rp.matched_at_end DESC"
      }],
      "fieldConfig": { "defaults": { "custom": { "align": "left" } }, "overrides": [
        { "matcher": { "id": "byRegexp", "options": ".*ms.*|.*dt.*" }, "properties": [{ "id": "unit", "value": "ms" }] }
      ]}
    },

    {
      "id": 40, "type": "logs", "title": "Raw events (last 200)",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT ts AS time, type, coalesce(user_id, '') AS user, payload::text AS message FROM events WHERE game_code = '$game_code' ORDER BY ts DESC LIMIT 200"
      }],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    }
  ]
}
