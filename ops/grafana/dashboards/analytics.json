{
  "uid": "tensies-analytics",
  "title": "Tensies — Player & Game Analytics",
  "tags": ["tensies", "analytics"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "1m",
  "panels": [
    {
      "id": 0, "type": "text", "title": "",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": {
        "mode": "html",
        "content": "<div style=\"display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 200 200\" role=\"img\" aria-label=\"Tensies\" style=\"width:120px;height:120px;filter:drop-shadow(0 12px 28px rgba(0,0,0,0.75)) drop-shadow(0 0 32px rgba(255,77,109,0.35));margin-bottom:-2.5rem;position:relative;z-index:2;\"><defs><filter id=\"t-glow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\"><feGaussianBlur stdDeviation=\"6\"/></filter><linearGradient id=\"t-pink\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\"><stop offset=\"0\" stop-color=\"#ff6b85\"/><stop offset=\"1\" stop-color=\"#e63a59\"/></linearGradient><linearGradient id=\"t-white\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\"><stop offset=\"0\" stop-color=\"#ffffff\"/><stop offset=\"1\" stop-color=\"#dcd9e8\"/></linearGradient></defs><g transform=\"translate(74 80) rotate(-14)\" opacity=\"0.55\"><rect x=\"-46\" y=\"-46\" width=\"92\" height=\"92\" rx=\"20\" fill=\"#ff4d6d\" filter=\"url(#t-glow)\"/></g><g transform=\"translate(74 80) rotate(-14)\"><rect x=\"-40\" y=\"-40\" width=\"80\" height=\"80\" rx=\"15\" fill=\"url(#t-pink)\" stroke=\"#2a0a14\" stroke-width=\"1.5\"/><rect x=\"-37\" y=\"-37\" width=\"74\" height=\"20\" rx=\"9\" fill=\"#ffffff\" opacity=\"0.12\"/><circle cx=\"-20\" cy=\"-22\" r=\"6\" fill=\"#fff\"/><circle cx=\"-20\" cy=\"0\" r=\"6\" fill=\"#fff\"/><circle cx=\"-20\" cy=\"22\" r=\"6\" fill=\"#fff\"/><circle cx=\"20\" cy=\"-22\" r=\"6\" fill=\"#fff\"/><circle cx=\"20\" cy=\"0\" r=\"6\" fill=\"#fff\"/><circle cx=\"20\" cy=\"22\" r=\"6\" fill=\"#fff\"/></g><g transform=\"translate(132 130) rotate(10)\"><rect x=\"-39\" y=\"-39\" width=\"78\" height=\"78\" rx=\"14\" fill=\"#1a1a2e\" opacity=\"0.35\" transform=\"translate(3 5)\"/><rect x=\"-38\" y=\"-38\" width=\"76\" height=\"76\" rx=\"14\" fill=\"url(#t-white)\" stroke=\"#1a1a2e\" stroke-width=\"1.5\"/><rect x=\"-35\" y=\"-35\" width=\"70\" height=\"18\" rx=\"8\" fill=\"#ffffff\" opacity=\"0.6\"/><circle cx=\"-19\" cy=\"-19\" r=\"6\" fill=\"#1a1a2e\"/><circle cx=\"19\" cy=\"-19\" r=\"6\" fill=\"#1a1a2e\"/><circle cx=\"-19\" cy=\"19\" r=\"6\" fill=\"#1a1a2e\"/><circle cx=\"19\" cy=\"19\" r=\"6\" fill=\"#1a1a2e\"/></g></svg><span style=\"font-family:system-ui,-apple-system,sans-serif;font-size:32px;font-weight:900;letter-spacing:0.15em;color:#ff4d6d;text-shadow:0 0 40px rgba(255,77,109,0.4);\">TENSIES</span></div>"
      },
      "transparent": true
    },
    {
      "id": 1, "type": "stat", "title": "Games (range)",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT count(*) FROM games WHERE started_ts >= $__timeFrom() AND started_ts < $__timeTo()"
      }],
      "fieldConfig": { "defaults": { "unit": "locale", "decimals": 0 } },
      "options": { "colorMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2, "type": "stat", "title": "Rounds (range)",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT count(*) FROM rounds WHERE started_ts >= $__timeFrom() AND started_ts < $__timeTo()"
      }],
      "fieldConfig": { "defaults": { "unit": "locale", "decimals": 0 } },
      "options": { "colorMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3, "type": "stat", "title": "Total rolls (range)",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT count(*) FROM events WHERE type = 'roll' AND ts >= $__timeFrom() AND ts < $__timeTo()"
      }],
      "fieldConfig": { "defaults": { "unit": "locale", "decimals": 0 } },
      "options": { "colorMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4, "type": "stat", "title": "Unique players (range)",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT count(DISTINCT user_id) FROM events WHERE user_id IS NOT NULL AND ts >= $__timeFrom() AND ts < $__timeTo()"
      }],
      "fieldConfig": { "defaults": { "unit": "locale", "decimals": 0 } },
      "options": { "colorMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5, "type": "stat", "title": "Sessions (range)",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT count(*) FROM sessions WHERE connected_ts >= $__timeFrom() AND connected_ts < $__timeTo()"
      }],
      "fieldConfig": { "defaults": { "unit": "locale", "decimals": 0 } },
      "options": { "colorMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6, "type": "stat", "title": "Total events stored",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT count(*) FROM events"
      }],
      "fieldConfig": { "defaults": { "unit": "locale", "decimals": 0 } },
      "options": { "colorMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },

    {
      "id": 10, "type": "table", "title": "Leaderboard — Most wins",
      "gridPos": { "h": 10, "w": 6, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT coalesce(name_last, user_id) AS \"Player\", total_wins AS \"Wins\", total_rounds AS \"Rounds\", round(100.0 * total_wins / NULLIF(total_rounds, 0), 1) AS \"Win %\" FROM player_stats ORDER BY total_wins DESC LIMIT 20"
      }],
      "fieldConfig": { "defaults": { "custom": { "align": "left" } }, "overrides": [
        { "matcher": { "id": "byName", "options": "Wins" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } }] }
      ]}
    },
    {
      "id": 11, "type": "table", "title": "Leaderboard — Fastest wins",
      "gridPos": { "h": 10, "w": 6, "x": 6, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT coalesce(name_last, user_id) AS \"Player\", fastest_win_ms AS \"Fastest (ms)\", fastest_win_rolls AS \"Fewest rolls\" FROM player_stats WHERE fastest_win_ms IS NOT NULL ORDER BY fastest_win_ms ASC LIMIT 20"
      }],
      "fieldConfig": { "defaults": {}, "overrides": [
        { "matcher": { "id": "byName", "options": "Fastest (ms)" }, "properties": [{ "id": "unit", "value": "ms" }, { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } }, { "id": "thresholds", "value": { "steps": [{ "color": "green" }, { "color": "yellow", "value": 15000 }, { "color": "red", "value": 60000 }] } }] }
      ]}
    },
    {
      "id": 12, "type": "table", "title": "Leaderboard — Most rolls",
      "gridPos": { "h": 10, "w": 6, "x": 12, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT coalesce(name_last, user_id) AS \"Player\", total_rolls AS \"Rolls\", total_sessions AS \"Sessions\", round(total_time_played_ms / 1000.0 / 60.0, 1) AS \"Minutes\" FROM player_stats ORDER BY total_rolls DESC LIMIT 20"
      }],
      "fieldConfig": { "defaults": {}, "overrides": [
        { "matcher": { "id": "byName", "options": "Rolls" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } }] }
      ]}
    },

    {
      "id": 13, "type": "table", "title": "Leaderboard — Luckiest players",
      "gridPos": { "h": 10, "w": 6, "x": 18, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT payload->>'name' AS \"Player\", COUNT(*) AS \"Rolls\", round(SUM(jsonb_array_length(payload->'newly_locked') - jsonb_array_length(payload->'rolled_values')::float / 6.0)::numeric, 1) AS \"Luck\" FROM events WHERE type = 'roll' AND ts >= $__timeFrom() AND ts < $__timeTo() GROUP BY payload->>'name' HAVING COUNT(*) >= 10 ORDER BY \"Luck\" DESC LIMIT 20"
      }],
      "fieldConfig": { "defaults": { "custom": { "align": "left" } }, "overrides": [
        { "matcher": { "id": "byName", "options": "Luck" }, "properties": [
          { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
          { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0 }, { "color": "green", "value": 5 }] } }
        ]}
      ]}
    },

    {
      "id": 20, "type": "histogram", "title": "Distribution: rolls per round",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT rolls AS \"rolls\" FROM round_player WHERE rolls > 0 AND game_code IN (SELECT game_code FROM games WHERE started_ts >= $__timeFrom() AND started_ts < $__timeTo())"
      }],
      "options": { "bucketSize": 5 }
    },
    {
      "id": 21, "type": "histogram", "title": "Distribution: round duration (s)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT (duration_ms / 1000.0)::float AS \"seconds\" FROM rounds WHERE duration_ms IS NOT NULL AND started_ts >= $__timeFrom() AND started_ts < $__timeTo()"
      }],
      "options": { "bucketSize": 10 }
    },
    {
      "id": 22, "type": "histogram", "title": "Distribution: session duration (min)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "table", "rawQuery": true,
        "rawSql": "SELECT (duration_ms / 60000.0)::float AS \"minutes\" FROM sessions WHERE duration_ms IS NOT NULL AND connected_ts >= $__timeFrom() AND connected_ts < $__timeTo()"
      }],
      "options": { "bucketSize": 1 }
    },

    {
      "id": 30, "type": "timeseries", "title": "Activity over time (rolls/min)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "time_series", "rawQuery": true,
        "rawSql": "SELECT date_trunc('minute', ts) AS time, count(*) AS rolls FROM events WHERE type = 'roll' AND ts >= $__timeFrom() AND ts < $__timeTo() GROUP BY 1 ORDER BY 1"
      }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 80 }, "unit": "short" } }
    },
    {
      "id": 31, "type": "barchart", "title": "Dice fairness (all-time)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by (value) (tensies_dice_value_total)", "refId": "A", "format": "table", "instant": true, "legendFormat": "{{value}}" }],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 80 } } },
      "options": { "orientation": "auto", "showValue": "auto", "legend": { "showLegend": false } }
    },

    {
      "id": 40, "type": "timeseries", "title": "Active players hourly",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "refId": "A", "format": "time_series", "rawQuery": true,
        "rawSql": "SELECT date_trunc('hour', ts) AS time, count(DISTINCT user_id) AS players FROM events WHERE user_id IS NOT NULL AND ts >= $__timeFrom() AND ts < $__timeTo() GROUP BY 1 ORDER BY 1"
      }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 30, "lineWidth": 2, "pointSize": 5, "showPoints": "always" } } }
    }
  ]
}
