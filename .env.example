# Copy to .env and set values for your environment.
# .env is gitignored — never commit it.

# Public URL Grafana is served at (used for share links, redirects, etc.)
GRAFANA_ROOT_URL=http://localhost:8889

# Discord game-status notifier (optional, off by default). When enabled, each
# game posts a single live-updating card to a channel. See docs/DISCORD.md.
# DISCORD_ENABLED=1
# DISCORD_BOT_TOKEN=your-bot-token
# DISCORD_CHANNEL_ID=123456789012345678
