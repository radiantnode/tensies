{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "strict": true,
    "lib": ["ES2022", "DOM"]
  },
  "include": ["src/**/*.mjs", "cli/**/*.mjs", "web/**/*.mjs", "test/**/*.mjs"]
}
